FROM node:20-alpine
WORKDIR /app

# Install dependencies
COPY package*.json ./
RUN npm install

# Copy all source code
COPY . .

# Run the build
RUN npm run build

# EXPOSE port 5000
EXPOSE 5000

# NEW START COMMAND: We use a wildcard to find the generated index.js
# This accounts for esbuild nested folder structures
CMD ["sh", "-c", "node $(find dist -name index.js | head -n 1)"]